{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Railmail",
  "colors": {
    "primary": "#5E6AD2",
    "light": "#7281FF",
    "dark": "#7C5CFF"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "languages": [
      {
        "language": "en",
        "tabs": [
          {
            "tab": "Guides",
            "pages": [
              {
                "group": "Getting Started",
                "pages": [
                  "en/index",
                  "en/quickstart"
                ]
              },
              {
                "group": "User Guide",
                "pages": [
                  "en/guide/getting-started",
                  "en/guide/building-with-ai",
                  "en/guide/subscribers",
                  "en/guide/topics",
                  "en/guide/segments",
                  "en/guide/custom-fields",
                  "en/guide/campaigns",
                  "en/guide/automations",
                  "en/guide/reports",
                  "en/guide/agents",
                  "en/guide/sending-domain",
                  "en/guide/preference-center",
                  "en/guide/team",
                  "en/guide/ai-credits"
                ]
              }
            ]
          },
          {
            "tab": "API Reference",
            "pages": [
              {
                "group": "Overview",
                "pages": [
                  "en/api-reference/introduction",
                  "en/api-reference/authentication",
                  "en/api-reference/errors",
                  "en/api-reference/rate-limits"
                ]
              },
              {
                "group": "Endpoints",
                "openapi": "api-reference/openapi.json"
              }
            ]
          }
        ]
      },
      {
        "language": "pl",
        "tabs": [
          {
            "tab": "Przewodniki",
            "pages": [
              {
                "group": "Pierwsze kroki",
                "pages": [
                  "pl/index",
                  "pl/quickstart"
                ]
              },
              {
                "group": "Przewodnik użytkownika",
                "pages": [
                  "pl/guide/getting-started",
                  "pl/guide/building-with-ai",
                  "pl/guide/subscribers",
                  "pl/guide/topics",
                  "pl/guide/segments",
                  "pl/guide/custom-fields",
                  "pl/guide/campaigns",
                  "pl/guide/automations",
                  "pl/guide/reports",
                  "pl/guide/agents",
                  "pl/guide/sending-domain",
                  "pl/guide/preference-center",
                  "pl/guide/team",
                  "pl/guide/ai-credits"
                ]
              }
            ]
          },
          {
            "tab": "Dokumentacja API",
            "pages": [
              {
                "group": "Wprowadzenie",
                "pages": [
                  "pl/api-reference/introduction",
                  "pl/api-reference/authentication",
                  "pl/api-reference/errors",
                  "pl/api-reference/rate-limits"
                ]
              },
              {
                "group": "Endpointy",
                "openapi": "api-reference/openapi.pl.json"
              }
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "API",
          "href": "https://api.railmail.app",
          "icon": "code"
        },
        {
          "anchor": "Portal",
          "href": "https://app.railmail.app",
          "icon": "gauge"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@railmail.app"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Portal",
      "href": "https://app.railmail.app"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/railmail",
      "github": "https://github.com/railmail",
      "linkedin": "https://linkedin.com/company/railmail"
    }
  }
}
